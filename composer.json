{
    "name": "primaybr/vertext",
    "description": "Vertext CMS - a modular, lightweight content management system built on the Phuse framework.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/",
            "Core\\": "Core/",
            "Config\\": "Config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
